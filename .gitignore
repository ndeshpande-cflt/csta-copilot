# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# --- Python / Ticket Lens app ---
# Secrets & per-user config — never share
.env
# Local cache: contains cached tickets AND saved Zendesk/Confluent cookies (PII)
cache.db
cache.db-journal
cache.db-wal
cache.db-shm

# Virtual environments
.venv/
venv/

# Python bytecode / caches
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Scratch
temp.txt

# Setup success marker (local state; run.sh gates on it)
.setup-complete

# Per-user customer list — names + org IDs are sensitive; never commit to a
# (public) repo. Each user keeps a local copy; see customers.example.json.
customers.json

# Generated per-cluster topic reports — contain decrypted topic names, which
# are sensitive customer data. Never commit.
resource-lens/report-gen/reports-output/

# Local Claude Code project settings — keep out of version control.
**/.claude/settings.json

# macOS
.DS_Store
