# Your Zendesk subdomain — the YOURCOMPANY in YOURCOMPANY.zendesk.com
ZENDESK_SUBDOMAIN=yourcompany

# Path to the Claude Code CLI. Leave as `claude` if it's on your PATH.
# If not, set the full path, e.g. /Users/yourname/.local/bin/claude
CLAUDE_CMD=claude

# Cache TTL for Zendesk responses, seconds. Default 10 min.
CACHE_TTL_SECONDS=600

# Your Zendesk session cookie. You normally DON'T set this by hand: ./run.sh
# opens a browser, you log in to Zendesk (SSO included), and the cookie is
# captured into this file for you as ZENDESK_COOKIE.
ZENDESK_COOKIE=
