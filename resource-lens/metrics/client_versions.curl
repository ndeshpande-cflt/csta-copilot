  --data-raw $'{"queries":[{"builder":{"intervals":{"intervals":["2026-05-27T13:11:14.427Z/2026-05-28T12:11:14.427Z"],"type":"intervals"},"query":"SELECT \\"user_resource_id\\" AS \\"principal\\", \\"client_id\\",\\n  \\"client_software_name\\", \\"client_software_version\\", SUM(\\"value_sum\\") as \\"connections\\"\\nFROM \\"telemetry_metrics_storage\\"\\nWHERE __time BETWEEN TIMESTAMPADD(HOUR, -1, CURRENT_TIMESTAMP) AND CURRENT_TIMESTAMP\\nAND \\"name\\" IN (\'io.confluent.kafka.server/tenant/connection_info_rate\')\\nAND \\"tenant\\" = \'lkc-22xqy\'\\nGROUP BY 1,2,3, 4\\nORDER BY 1, 2\\nLIMIT 1001","queryType":"sql"},"datasource":{"type":"confluent-druid-datasource","uid":"_Pvp4KNVk"},"refId":"A","settings":{},"expr":"{\\"builder\\":{\\"queryType\\":\\"sql\\",\\"query\\":\\"SELECT \\\\\\"user_resource_id\\\\\\" AS \\\\\\"principal\\\\\\", \\\\\\"client_id\\\\\\",\\\\n  \\\\\\"client_software_name\\\\\\", \\\\\\"client_software_version\\\\\\", SUM(\\\\\\"value_sum\\\\\\") as \\\\\\"connections\\\\\\"\\\\nFROM \\\\\\"telemetry_metrics_storage\\\\\\"\\\\nWHERE __time BETWEEN TIMESTAMPADD(HOUR, -1, CURRENT_TIMESTAMP) AND CURRENT_TIMESTAMP\\\\nAND \\\\\\"name\\\\\\" IN (\'io.confluent.kafka.server/tenant/connection_info_rate\')\\\\nAND \\\\\\"tenant\\\\\\" = \'$resourceKafkaId\'\\\\nGROUP BY 1,2,3, 4\\\\nORDER BY 1, 2\\\\nLIMIT 1001\\",\\"intervals\\":{\\"type\\":\\"intervals\\",\\"intervals\\":[\\"${__from:date:iso}/${__to:date:iso}\\"]}},\\"settings\\":{}}","datasourceId":6,"intervalMs":60000,"maxDataPoints":1358}],"from":"1779887474427","to":"1779970274427"}'