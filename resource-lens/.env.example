# Your admin.confluent.cloud session cookie (contains internal_auth_token=<JWT>).
# Copy it from DevTools → Network → any confluent.cloud/api/internal/… request
# → Copy as cURL, then paste just the cookie string here (or the whole -b '...').
CONFLUENT_COOKIE=

# How long to cache Confluent Cloud API responses, in seconds. Default 10 min.
CACHE_TTL_SECONDS=600
