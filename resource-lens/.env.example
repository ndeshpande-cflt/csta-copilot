# Your admin.confluent.cloud session cookie (contains internal_auth_token=<JWT>).
#
# You normally DON'T fill this in by hand: ./run.sh opens a browser, you log in
# to admin.confluent.cloud, and the cookie is captured into this file for you.
# (To set it manually: DevTools → Network → any confluent.cloud/api/internal/…
# request → Copy as cURL, then paste just the cookie string here.)
CONFLUENT_COOKIE=

# How long to cache Confluent Cloud API responses, in seconds. Default 10 min.
CACHE_TTL_SECONDS=600
